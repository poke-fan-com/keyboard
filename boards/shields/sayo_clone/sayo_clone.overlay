/ {
    keys {
        compatible = "zmk,keys";

        sw1 { gpios = <&gpio0 17 GPIO_ACTIVE_LOW>; };
        sw2 { gpios = <&gpio0 20 GPIO_ACTIVE_LOW>; };
        sw3 { gpios = <&gpio0 22 GPIO_ACTIVE_LOW>; };
        sw4 { gpios = <&gpio0 24 GPIO_ACTIVE_LOW>; };
        sw5 { gpios = <&gpio1 0 GPIO_ACTIVE_LOW>; };
        sw6 { gpios = <&gpio0 11 GPIO_ACTIVE_LOW>; };
    };
};
